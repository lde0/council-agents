{
  "model": "anthropic/claude-sonnet-4-6",
  "thinking": "adaptive",
  "role": "orchestrator",
  "description": "Council orchestrator — manages discourse flow, eagerness scoring, and agent sequencing. Never posts directly to threads.",
  "eagerness": {
    "responseThreshold": 0.30,
