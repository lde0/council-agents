{
  "model": "anthropic/claude-sonnet-4-6",
  "thinking": "adaptive",
  "role": "orchestrator",
  "description": "Council orchestrator — manages discourse flow, eagerness scoring, and agent sequencing. Never posts directly to threads.",
  "eagerness": {
    "responseThreshold": 0.30,
    "exceptionThreshold": 0.85,
    "suppressionPerResponse": 0.25,
    "suppressionLiftPerOtherResponse": 0.03,
    "suppressionCap": 0.80,
    "roundDecay": [1.0, 0.70, 0.45]
  },
  "termination": {
    "initialMaxRounds": 3,
    "followUpMaxRounds": 1,
    "exceptionAllowance": 1
  }
}
