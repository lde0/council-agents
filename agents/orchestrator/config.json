    "suppressionPerResponse": 0.20,
    "suppressionLiftPerOtherResponse": 0.05,
    "suppressionCap": 0.80
  },
  "termination": {
    "initialMaxRounds": 3,
    "followUpMaxRounds": 1,
    "exceptionAllowance": 1
  }
}
